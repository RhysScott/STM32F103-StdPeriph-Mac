#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

PROJECT_NAME="STM32F103C8T6"
BUILD_DIR="build"
FLASH_ADDR="0x08000000"

log_ok()  { echo -e "${GREEN}✓${NC} $1"; }
log_err() { echo -e "${RED}✗${NC} $1" >&2; }

cmd_check() {
    for tool in arm-none-eabi-gcc cmake make st-flash; do
        command -v "$tool" &>/dev/null || { log_err "缺少 $tool"; return 1; }
    done
    log_ok "环境就绪"
}

cmd_clean() {
    rm -rf "$BUILD_DIR" && log_ok "已清理" || log_ok "无需清理"
}

cmd_build() {
    local type="${BUILD_TYPE:-Debug}"
    echo "编译 ($type)..."
    mkdir -p "$BUILD_DIR"
    cmake -B "$BUILD_DIR" -DCMAKE_BUILD_TYPE="$type" > /dev/null || { log_err "CMake 失败"; return 1; }
    cmake --build "$BUILD_DIR" -- -j$(sysctl -n hw.ncpu 2>/dev/null || nproc 2>/dev/null || echo 4) || return 1
    log_ok "编译完成 → ${BUILD_DIR}/${PROJECT_NAME}.bin"
}

cmd_flash() {
    local bin="${BUILD_DIR}/${PROJECT_NAME}.bin"
    [[ -f "$bin" ]] || { log_err "未找到 $bin — 先 build"; return 1; }
    st-flash write "$bin" "$FLASH_ADDR" && log_ok "烧录完成" || { log_err "烧录失败"; return 1; }
}

cmd_reset() {
    st-flash reset && log_ok "已重置" || log_err "重置失败"
}

cmd_full() {
    cmd_check && cmd_clean && cmd_build && cmd_flash && log_ok "全流程完成"
}

show_help() {
    echo "用法: ./f1flow <命令> [命令...]"
    echo ""
    echo "命令:"
    echo "  check   检查工具链"
    echo "  clean   清理构建"
    echo "  build   编译 (BUILD_TYPE=Debug/Release)"
    echo "  flash   烧录"
    echo "  reset   重置设备"
    echo "  full    check → clean → build → flash"
    echo "  help    帮助"
    echo ""
    echo "示例:"
    echo "  ./f1flow build flash"
    echo "  BUILD_TYPE=Release ./f1flow clean build flash"
}

main() {
    [[ $# -eq 0 ]] && { show_help; exit 0; }
    for cmd in "$@"; do
        case "$cmd" in
            check) cmd_check || exit 1 ;;
            clean) cmd_clean ;;
            build) cmd_build || exit 1 ;;
            flash) cmd_flash || exit 1 ;;
            reset) cmd_reset ;;
            full)  cmd_full || exit 1 ;;
            help)  show_help; exit 0 ;;
            *)     log_err "未知命令: $cmd"; show_help; exit 1 ;;
        esac
    done
}

main "$@"
