{
    "configurations": [
        {
            "name": "STM32F103 (arm-none-eabi-gcc)",
            "includePath": [
                "${workspaceFolder}/inc/driver",
                "${workspaceFolder}/inc/user",
                "${workspaceFolder}/src/system"
            ],
            "defines": [
                "USE_STDPERIPH_DRIVER",
                "STM32F10X_MD",
                "HSE_VALUE=8000000U"
            ],
            "compilerPath": "arm-none-eabi-gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm"
        }
    ],
    "version": 4
}
